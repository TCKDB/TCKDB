# ============================================================================
# TCKDB - HPC client environment (EXAMPLE / PLACEHOLDERS ONLY)
#
# Per-user env file for batch jobs / HPC scripts that act as TCKDB API
# clients.  Copy to a private location, replace the placeholder API key,
# and source it from your job script:
#
#   mkdir -p "$HOME/.config/tckdb"
#   cp examples/deployment/hpc-client.env.example "$HOME/.config/tckdb/env"
#   chmod 600 "$HOME/.config/tckdb/env"
#   # ... edit and replace TCKDB_API_KEY ...
#
# Inside a job:
#
#   . "$HOME/.config/tckdb/env"
#
# This file contains NO secrets.  The API key value is a placeholder and
# must be replaced with a key minted on the target instance for YOUR user.
# Do NOT commit the resulting file back to the repo.
#
# Policy reminders (see docs/deployment/client-access-from-hpc.md):
#   - One API key per user, not per lab.
#   - Distinct labels per environment (alice-laptop, alice-hpc, ...).
#   - Revoke immediately if leaked.
#   - HPC jobs are CLIENTS - they do not run a TCKDB DB or backend per job.
# ============================================================================

# Base URL of the TCKDB instance to upload to.  Typically a lab-server URL,
# but the same shape works for hosted/community TCKDB by changing this URL
# (and using a key minted on that instance).
TCKDB_BASE_URL=https://tckdb.lab.example.org/api/v1

# Per-user API key, minted on the instance referenced by TCKDB_BASE_URL.
# Replace `tck_replace_me` before use.  Keys are bearer credentials.
TCKDB_API_KEY=tck_replace_me
