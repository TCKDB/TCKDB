# ============================================================================
# TCKDB - Lab-server deployment environment (EXAMPLE / PLACEHOLDERS ONLY)
#
# Reference env file for a private shared lab-server deployment.  Copy to
# .env on the lab service host and replace every placeholder before use:
#
#   cp examples/deployment/lab-server.env.example .env
#
# This file contains NO secrets.  Every credential below is a placeholder
# (`change-me`, `replace-me`, etc.) and must be replaced before the server
# is started.  Do NOT commit the resulting .env back to the repo.
#
# This is the lab-server analogue of `.env.local.example`.  Differences:
#   - Open registration is OFF.
#   - The API binds to 0.0.0.0 (reachable behind the reverse proxy).
#   - TCKDB_PUBLIC_BASE_URL is set to the lab-visible URL.
#
# See: docs/deployment/shared-private-deployment.md
# ============================================================================

# -- PostgreSQL (with RDKit cartridge) ---------------------------------------
# Use a dedicated DB user/password for the lab deployment - do not reuse
# values from the local example file.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=tckdb_lab
DB_USER=tckdb
DB_PASSWORD=change-me-strong-db-password
DB_CLIENT_ENCODING=utf8

# -- MinIO / S3 artifact storage ---------------------------------------------
# Either keep MinIO on the same host (default) or point S3_ENDPOINT_URL at
# a lab-managed S3 service.  Replace the access keys with strong values.
S3_ENDPOINT_URL=http://127.0.0.1:9000
S3_ACCESS_KEY=replace-me-s3-access
S3_SECRET_KEY=replace-me-s3-secret
S3_BUCKET=tckdb-artifacts
S3_REGION=us-east-1

# -- Authentication / registration policy ------------------------------------
# Shared lab-server deployments MUST disable open registration.  Seed
# accounts with scripts/bootstrap_admin.py instead.  Re-enabling this on a
# reachable server is a soft account-creation backdoor - don't.
AUTH_ALLOW_OPEN_REGISTRATION=false

# -- Upload worker -----------------------------------------------------------
# Inline worker is fine for a small lab; flip to false and run
# `python -m app.workers.upload_worker` under systemd if you want isolation.
TCKDB_INLINE_WORKER=true

# -- Backend API binding -----------------------------------------------------
# Bind to all interfaces; the reverse proxy is what the network sees.  The
# proxy is responsible for TLS termination, X-API-Key passthrough, and
# preserving the session cookie.
TCKDB_API_HOST=0.0.0.0
TCKDB_API_PORT=8010

# Public base URL the lab uses to reach this deployment.  Clients (scripts,
# notebooks, HPC jobs) configure this as their TCKDB_BASE_URL.
TCKDB_PUBLIC_BASE_URL=https://tckdb.lab.example.org/api/v1
