# ============================================================================
# TCKDB - Self-hosted single-node deployment environment
# (EXAMPLE / PLACEHOLDERS)
#
# Copy to .env.selfhosted on the host and replace every `change-me-*` value:
#   cp .env.selfhosted.example .env.selfhosted
# Do NOT commit the resulting file.
#
# Reference doc: docs/deployment/self_hosted_single_node.md
# Production checklist (verify every value before exposing the API):
#                docs/deployment/production_checklist.md
# Compose file:  docker-compose.yml (canonical, no -f needed)
#                Pass `--env-file .env.selfhosted` to load these values.
#
# This file targets a *hosted* single-node deployment: anonymous
# scientific reads are allowed, but every abuse-control knob is on,
# docs are off, legacy routes require auth, internal IDs are hidden,
# and the API is reachable only via a reverse-proxy/tunnel terminating
# on the host. Cloudflare Tunnel is one option (see the optional
# "Ingress" section near the bottom); nginx, Caddy, Traefik,
# Tailscale, WireGuard, etc. are equally valid.
# ============================================================================

# ----------------------------------------------------------------------------
# Deployment mode
# ----------------------------------------------------------------------------
# Activates the startup safety guard. In `shared_private` and
# `hosted_public` the API refuses to boot when any of the required
# hosted settings below is at an unsafe value. Use `hosted_public`
# for internet-facing deployments, `shared_private` for lab-internal,
# and `local` for single-developer laptops (default if unset).
DEPLOYMENT_MODE=hosted_public

# ----------------------------------------------------------------------------
# PostgreSQL (RDKit cartridge image)
# ----------------------------------------------------------------------------
# Bound to 127.0.0.1 only inside docker-compose.yml. Never expose 5432
# on the public interface.
#
# Host vs container ports: the compose file publishes the DB as
#   127.0.0.1:${DB_PORT:-5432} -> container port 5432
# Set DB_HOST/DB_PORT for the *consumer*:
#   host-run API/Alembic (this recipe's default):
#     DB_HOST=127.0.0.1, DB_PORT=<host-published port>
#   API inside compose (future containerized API):
#     DB_HOST=db,        DB_PORT=5432
# (See docs/deployment/troubleshooting.md, "host port vs container port".)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=tckdb
DB_USER=tckdb
DB_PASSWORD=change-me-strong-db-password
DB_CLIENT_ENCODING=utf8

# Postgres session statement_timeout (ms). Belt-and-braces: the doc also
# sets this at the role level via `ALTER ROLE tckdb SET statement_timeout`.
DB_STATEMENT_TIMEOUT_MS=30000

# ----------------------------------------------------------------------------
# MinIO / S3 artifact storage
# ----------------------------------------------------------------------------
# Bound to 127.0.0.1 only. The MinIO console (9001) is NEVER published
# to the tunnel - see docker-compose.yml.
S3_ENDPOINT_URL=http://127.0.0.1:9000
S3_ACCESS_KEY=change-me-s3-access-key
S3_SECRET_KEY=change-me-s3-secret-key
S3_BUCKET=tckdb-artifacts
S3_REGION=us-east-1

# ----------------------------------------------------------------------------
# Hosted abuse-control posture (security phase 1)
# ----------------------------------------------------------------------------
# Master switch for the application-level rate limiter. MUST be true.
RATE_LIMIT_ENABLED=true

# Per-minute budgets. Buckets are split by route class — see
# docs/specs/public_read_abuse_controls.md for the full bucket table.
# Conservative starting values; tune up only after observing
# legitimate-traffic patterns.
#
# Anonymous + authenticated public scientific reads.
RATE_LIMIT_ANON_READ_PER_MINUTE=60
RATE_LIMIT_AUTH_READ_PER_MINUTE=300
# Authenticated mutating routes (uploads, admin, etc.). Tight on
# purpose so one misbehaving uploader cannot exhaust the deployment.
RATE_LIMIT_AUTH_WRITE_PER_MINUTE=30
# Anonymous everything-else (including stray anonymous mutations).
# Smaller than ANON_READ so anonymous writes do not inherit the
# generous read budget.
RATE_LIMIT_ANON_OTHER_PER_MINUTE=20
# Auth-surface throttles (credential-stuffing / account-spam).
RATE_LIMIT_AUTH_LOGIN_PER_MINUTE=10
RATE_LIMIT_REGISTER_PER_HOUR=10

# Trusted proxy header. Set this to the header your ingress layer
# injects unconditionally (and that an upstream client cannot forge).
#
# Choose the value to match your ingress:
#   Cloudflare Tunnel / Cloudflare proxy:  CF-Connecting-IP
#   nginx (proxy_set_header X-Real-IP):    X-Real-IP
#   Traefik / Caddy with X-Forwarded-For:  X-Forwarded-For
#                                          (only if the proxy strips
#                                           any client-supplied value)
#
# Leave unset if the API is reached on `127.0.0.1` with no proxy
# (development / local-only). The default below assumes Cloudflare
# Tunnel — change it if you swap ingress.
TRUSTED_PROXY_HEADER=CF-Connecting-IP

# Per-public-read query caps (defaults shown for documentation; uncomment
# to tighten further on a memory- or CPU-constrained host).
# PUBLIC_MAX_LIMIT=200
# PUBLIC_MAX_OFFSET=10000
# MAX_GEOMETRY_ATOMS_PUBLIC=500
# MAX_FULL_CALCULATIONS_PUBLIC=100
# MAX_FULL_GEOMETRIES_PUBLIC=100
# MAX_FULL_ARTIFACTS_PUBLIC=100

# OpenAPI / Swagger / ReDoc. MUST be false for public deployments.
EXPOSE_API_DOCS=false

# Legacy /api/v1/{thermo,kinetics,...} entity routes. MUST require auth
# in hosted deployments - they leak integer PKs.
LEGACY_READS_REQUIRE_AUTH=true

# Internal-ID visibility policy. MUST be false in hosted: clients use
# public refs as handles.
ALLOW_PUBLIC_INTERNAL_IDS=false

# Session cookie posture. `secure=true` requires that the ingress
# terminates TLS at the edge (Cloudflare Tunnel does this; nginx/Caddy
# with a managed cert do too). Set to false ONLY for testing a local
# HTTP-only setup.
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_HTTPONLY=true

# CORS - leave empty unless a known browser-app origin needs to call
# the API. An empty list disables the CORS middleware entirely, which
# is the correct hosted default.
# CORS_ALLOW_ORIGINS=https://app.tckdb.example.org
# CORS_ALLOW_CREDENTIALS=true

# ----------------------------------------------------------------------------
# Auth / registration policy
# ----------------------------------------------------------------------------
# Closed registration. Seed accounts via scripts/bootstrap_admin.py and
# the /admin invite flow.
AUTH_ALLOW_OPEN_REGISTRATION=false

# ----------------------------------------------------------------------------
# API binding and upload worker
# ----------------------------------------------------------------------------
# Bind to localhost only - the ingress layer (Cloudflare Tunnel,
# nginx, Caddy, ...) is the only thing that talks to the API. There
# is no router port-forward.
TCKDB_API_HOST=127.0.0.1
TCKDB_API_PORT=8010

# Public base URL clients use. This is whatever hostname your ingress
# layer exposes.
TCKDB_PUBLIC_BASE_URL=https://api.tckdb.example.org/api/v1

# Inline worker is acceptable for a small single-node deployment.
# Flip to false and run a separate worker unit if upload volume
# saturates the API process.
TCKDB_INLINE_WORKER=true

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
# LOG_LEVEL: DEBUG / INFO / WARNING / ERROR. INFO is the recommended
# hosted default; raise to WARNING on a very memory-constrained host.
LOG_LEVEL=INFO

# LOG_FORMAT: `text` (human-readable, dev default) or `json` (one JSON
# object per line, includes request_id / level / logger / message /
# timestamp). Use `json` when logs are shipped to journald/ELK/Datadog
# or any structured log collector. Both formats include request_id when
# available.
LOG_FORMAT=json

# ----------------------------------------------------------------------------
# Ingress (OPTIONAL): Cloudflare Tunnel
# ----------------------------------------------------------------------------
# Required ONLY if you bring up the `cloudflared` service via the
# `cloudflare` Compose profile. nginx / Caddy / Traefik / Tailscale /
# WireGuard / a host-side cloudflared / etc. do not need this variable;
# they have their own config. Leave commented if you do not use the
# Compose cloudflared service.
#
# Provisioned out-of-band in the Cloudflare Zero Trust dashboard
# (Networks -> Tunnels -> Create a tunnel -> Cloudflared). Treat it
# like a long-lived bearer token; do not commit a populated value.
#
# CLOUDFLARED_TUNNEL_TOKEN=eyJhIjoi...   # from the Zero Trust UI
