  product
}

enum RecordReviewStatus {
  not_reviewed
  under_review
  approved
  rejected
  deprecated
}

enum RigidRotorKind {
  atom
  linear
  spherical_top
  symmetric_top
  asymmetric_top
}

enum ScanCoordinateKind {
  bond
  angle
  dihedral
  improper
}

enum ScientificOriginKind {
  computed
  experimental
  estimated
}

enum SpeciesEntryReviewRole {
  curator
  reviewer
  validator
  linker
}

enum SpeciesEntryStateKind {
  ground
  excited
}

enum StationaryPointKind {
  minimum
  vdw_complex
}

enum StatmechCalculationRole {
  opt
