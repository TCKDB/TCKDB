enum TransportCalculationRole {
  full_transport
  dipole
  polarizability
  supporting_geometry
}

enum UploadJobKind {
  computed_reaction
  conformer
  reaction
  kinetics
  network
  network_pdep
  thermo
  transition_state
  transport
}

enum UploadJobStatus {
  queued
  processing
  complete
  failed
}

enum ValidationStatus {
  passed
  warning
  fail
}

Table app_user {
  id bigint [pk, not null]
  username text [not null]
  email text
  full_name text
  affiliation text
  orcid varchar(19)
  password_hash text
  is_active boolean [not null, default: 'true']
  role AppUserRole [not null, default: 'user']
  created_at timestamp [not null, default: 'now']

  indexes {
    orcid [unique, name: 'uq_app_user_orcid']
    email [unique, name: 'uq_app_user_email']
    username [unique, name: 'uq_app_user_username']
  }

  Note: 'Application user identity used for curation provenance and auth.'
}

Table author {
  id bigint [pk, not null]
  given_name text
  family_name text [not null]
  full_name text [not null]
  orcid varchar(19)
  created_at timestamp [not null, default: 'now']

  indexes {
    orcid [unique, name: 'uq_author_orcid']
  }
}

Table calculation_parameter_vocab {
  canonical_key text [pk, not null]
  description text
  expected_value_type text
  affects_scientific_result boolean
  affects_numerics boolean
  affects_resources boolean
  note text
  created_at timestamp [not null, default: 'now']

  Note: 'Ontology seed for canonical parameter keys.'
}

Table geometry {
  id bigint [pk, not null]
  natoms int [not null]
  geom_hash varchar(64) [not null]
  xyz_text text
  created_at timestamp [not null, default: 'now']

  indexes {
    geom_hash [unique, name: 'uq_geometry_geom_hash']
  }

  checks {
    `natoms >= 1` [name: 'ck_geometry_natoms_ge_1']
  }

  Note: 'Stores a reusable molecular geometry and its serialized XYZ form.'
}

Table level_of_theory {
  id bigint [pk, not null]
  method text [not null]
  basis text
  aux_basis text
  cabs_basis text
  dispersion text
  solvent text
  solvent_model text
  keywords text
  lot_hash varchar(64) [not null]
  created_at timestamp [not null, default: 'now']

  indexes {
    lot_hash [unique, name: 'uq_level_of_theory_lot_hash']
  }

  Note: 'Method/basis provenance used by calculations.'
}

Table literature {
  id bigint [pk, not null]
  kind LiteratureKind [not null]
  title text [not null]
  journal text
  year int
  volume text
  issue text
  pages text
  doi text
  isbn text
  url text
  publisher text
  institution text
  created_at timestamp [not null, default: 'now']

  indexes {
    () [name: 'ix_literature_isbn_normalized']
    () [name: 'ix_literature_doi_normalized']
  }
}

Table reaction_family {
  id bigint [pk, not null]
  name text [not null]
  created_at timestamp [not null, default: 'now']

  indexes {
    name [unique, name: 'uq_reaction_family_name']
  }
}

Table software {
  id bigint [pk, not null]
  name text [not null]
  website text
  description text
  created_at timestamp [not null, default: 'now']

  indexes {
    name [unique, name: 'uq_software_name']
  }

  Note: 'Stable identity of a software package.'
}

Table species {
  id bigint [pk, not null]
  kind MoleculeKind [not null]
  smiles text [not null]
  inchi_key varchar(27) [not null]
  charge int [not null]
  multiplicity int [not null]
  stereo_kind StereoKind [not null]
  created_at timestamp [not null, default: 'now']

  indexes {
    inchi_key [unique, name: 'uq_species_inchi_key']
  }

  checks {
    `multiplicity >= 1` [name: 'ck_species_multiplicity_ge_1']
  }

  Note: 'Store graph-defined species identities without resolved stereo or 3D conformers.'
}

Table workflow_tool {
  id bigint [pk, not null]
  name text [not null]
  description text
  created_at timestamp [not null, default: 'now']

  indexes {
    name [unique, name: 'uq_workflow_tool_name']
  }

  Note: 'Stable identity for a workflow or orchestration tool.'
}

Table api_key {
  id bigint [pk, not null]
  user_id bigint [not null, ref: > app_user.id]
  key_hash varchar(64) [not null]
  label text
  last_used_at timestamp
  revoked_at timestamp
  created_at timestamp [not null, default: 'now']

  indexes {
    key_hash [unique, name: 'uq_api_key_key_hash']
  }

  Note: 'API keys owned by an :class:`AppUser`.'
}

Table chem_reaction {
  id bigint [pk, not null]
  stoichiometry_hash varchar(64)
  reversible boolean [not null]
  reaction_family_id bigint [ref: > reaction_family.id]
  reaction_family_raw text
  reaction_family_source_note text
  created_at timestamp [not null, default: 'now']

  indexes {
    stoichiometry_hash [unique, name: 'uq_chem_reaction_stoichiometry_hash']
  }

  checks {
    `reaction_family_raw IS NULL OR reaction_family_source_note IS NOT NULL` [name: 'ck_chem_reaction_reaction_family_raw_requires_source_note']
  }
}

Table conformer_assignment_scheme {
  id bigint [pk, not null]
  name string [not null]
  version string [not null]
  scope ConformerAssignmentScopeKind [not null, default: 'canonical']
  description text
  parameters_json jsonb
  code_commit string
  is_default boolean [not null, default: 'false']
  created_at timestamp [not null, default: 'now']
  created_by bigint [ref: > app_user.id]

  indexes {
    (name, version) [unique, name: 'uq_conformer_assignment_scheme_name']
  }

  Note: 'Store versioned metadata about conformer-assignment or selection logic.'
}

Table energy_correction_scheme {
  id bigint [pk, not null]
  kind EnergyCorrectionSchemeKind [not null]
  name text [not null]
  level_of_theory_id bigint [ref: > level_of_theory.id]
  source_literature_id bigint [ref: > literature.id]
  version text
  units EnergyUnit
  note text
  created_at timestamp [not null, default: 'now']
  created_by bigint [ref: > app_user.id]

  indexes {
    (kind, name, level_of_theory_id, version) [unique, name: 'uq_energy_correction_scheme_kind_name_lot_version']
  }

  Note: 'Reusable energy-correction parameter set.'
}

Table geometry_atom {
  geometry_id bigint [not null, ref: > geometry.id]
  atom_index int [not null]
  element varchar(2) [not null]
  x double [not null]
  y double [not null]
  z double [not null]

  indexes {
    (atom_index, geometry_id) [pk]
  }

  checks {
    `atom_index >= 1` [name: 'ck_geometry_atom_atom_index_ge_1']
  }

  Note: 'Stores per-atom coordinates for a geometry row.'
}

Table idempotency_record {
  id bigint [pk, not null]
  user_id bigint [not null, ref: > app_user.id]
  request_method string [not null]
  endpoint text [not null]
  idempotency_key string [not null]
  payload_hash varchar(64) [not null]
  status_code int [not null]
  response_body_json jsonb [not null]
  expires_at timestamp [not null]
  created_at timestamp [not null, default: 'now']

  indexes {
    (user_id, request_method, endpoint, idempotency_key) [unique, name: 'uq_idempotency_record_user_method_endpoint_key']
  }

  Note: 'Server-side retry-safety record for a successful keyed write.'
}

Table literature_author {
  literature_id bigint [not null, ref: > literature.id]
  author_id bigint [not null, ref: > author.id]
  author_order int [not null]

  indexes {
    (author_id, literature_id) [pk]
    (literature_id, author_order) [unique, name: 'uq_literature_author_literature_id']
  }
}

Table software_release {
  id bigint [pk, not null]
  software_id bigint [not null, ref: > software.id]
  version text
  revision text
  build text
  release_date date
  notes text
  created_at timestamp [not null, default: 'now']

  indexes {
    (software_id, version, revision, build) [unique, name: 'uq_software_release_software_id']
  }

  Note: 'Exact release metadata for a software package.'
}

Table species_entry {
  id bigint [pk, not null]
  species_id bigint [not null, ref: > species.id]
  kind StationaryPointKind [not null, default: 'minimum']
  mol mol
  unmapped_smiles text
  stereo_label string
  electronic_state_kind SpeciesEntryStateKind [not null, default: 'ground']
  electronic_state_label string
  term_symbol_raw string
  term_symbol string
  isotopologue_label string
  created_at timestamp [not null, default: 'now']
  created_by bigint [ref: > app_user.id]

  indexes {
    species_id [name: 'ix_species_entry_species_id']
    (species_id, stereo_label, electronic_state_kind, electronic_state_label, term_symbol, isotopologue_label) [unique, name: 'uq_species_entry_species_id']
  }

  Note: 'Store one stereochemically, electronically, or isotopically resolved species form.'
}

Table upload_job {
  id uuid [pk, not null, default: 'gen_random_uuid()']
  status UploadJobStatus [not null, default: 'queued']
  kind UploadJobKind [not null]
  payload jsonb [not null]
  created_by bigint [ref: > app_user.id]
  created_at timestamp [not null, default: 'now']
  started_at timestamp
  completed_at timestamp
  result jsonb
  error text
  attempts int [not null, default: '0']
  max_attempts int [not null, default: '3']

  indexes {
    (status, created_at) [name: 'ix_upload_job_status_created_at']
  }

  Note: 'Async upload job queue backed by PostgreSQL.'
}

Table user_session {
  id bigint [pk, not null]
  user_id bigint [not null, ref: > app_user.id]
  token_hash varchar(64) [not null]
  expires_at timestamp [not null]
  revoked_at timestamp
  created_at timestamp [not null, default: 'now']

  indexes {
    token_hash [unique, name: 'uq_user_session_token_hash']
  }

  Note: 'Server-side session record for human browser authentication.'
}

Table workflow_tool_release {
  id bigint [pk, not null]
  workflow_tool_id bigint [not null, ref: > workflow_tool.id]
  version text
  git_commit varchar(40)
  release_date date
  notes text
  created_at timestamp [not null, default: 'now']

  indexes {
    (workflow_tool_id, version, git_commit) [unique, name: 'uq_workflow_tool_release_workflow_tool_id']
  }

  Note: 'Exact provenance for a workflow tool code state.'
}

Table conformer_group {
  id bigint [pk, not null]
  species_entry_id bigint [not null, ref: > species_entry.id]
  label string
  note text
  representative_fingerprint_json jsonb
  representative_coords_json jsonb
  created_at timestamp [not null, default: 'now']
  created_by bigint [ref: > app_user.id]

  indexes {
    species_entry_id [name: 'ix_conformer_group_species_entry_id']
    (species_entry_id, label) [unique, name: 'uq_conformer_group_species_entry_id']
  }

  Note: 'Store one deduplicated conformational-basin identity for a species entry.'
}

Table energy_correction_scheme_atom_param {
  scheme_id bigint [not null, ref: > energy_correction_scheme.id]
  element text [not null]
  value double [not null]

  indexes {
    (element, scheme_id) [pk]
  }

  Note: 'Element-keyed scalar parameter within a correction scheme.'
}

Table energy_correction_scheme_bond_param {
  scheme_id bigint [not null, ref: > energy_correction_scheme.id]
  bond_key text [not null]
  value double [not null]

  indexes {
    (bond_key, scheme_id) [pk]
  }

  Note: 'Bond-type keyed scalar parameter within a correction scheme.'
}

Table energy_correction_scheme_component_param {
  scheme_id bigint [not null, ref: > energy_correction_scheme.id]
  component_kind MeliusBacComponentKind [not null]
  key text [not null]
  value double [not null]

  indexes {
    (component_kind, key, scheme_id) [pk]
  }

  Note: 'Multi-component parameter within a correction scheme.'
}

Table frequency_scale_factor {
  id bigint [pk, not null]
  level_of_theory_id bigint [not null, ref: > level_of_theory.id]
  software_id bigint [ref: > software.id]
  scale_kind FrequencyScaleKind [not null]
  value double [not null]
  source_literature_id bigint [ref: > literature.id]
  workflow_tool_release_id bigint [ref: > workflow_tool_release.id]
  note text
  created_at timestamp [not null, default: 'now']
  created_by bigint [ref: > app_user.id]

  indexes {
    (level_of_theory_id, software_id, scale_kind, value, source_literature_id, workflow_tool_release_id) [unique, name: 'uq_frequency_scale_factor_identity']
  }

  checks {
    `value > 0` [name: 'ck_frequency_scale_factor_value_gt_0']
  }

  Note: 'Immutable registry row for one frequency scale factor definition.'
}

Table network {
  id bigint [pk, not null]
  name text
  description text
  literature_id bigint [ref: > literature.id]
  software_release_id bigint [ref: > software_release.id]
  workflow_tool_release_id bigint [ref: > workflow_tool_release.id]
  created_at timestamp [not null, default: 'now']
  created_by bigint [ref: > app_user.id]

  Note: 'Reaction network metadata.'
}

Table reaction_entry {
  id bigint [pk, not null]
  reaction_id bigint [not null, ref: > chem_reaction.id]
  created_at timestamp [not null, default: 'now']
  created_by bigint [ref: > app_user.id]
}

Table reaction_participant {
  reaction_id bigint [not null, ref: > chem_reaction.id]
  species_id bigint [not null, ref: > species.id]
  role ReactionRole [not null]
  stoichiometry int [not null]

  indexes {
    (reaction_id, role, species_id) [pk]
  }

  checks {
    `stoichiometry >= 1` [name: 'ck_reaction_participant_stoichiometry_ge_1']
  }

  Note: 'Compressed stoichiometric summary for a reaction graph identity.'
}

Table species_entry_review {
  id bigint [pk, not null]
  species_entry_id bigint [not null, ref: > species_entry.id]
  user_id bigint [not null, ref: > app_user.id]
  role SpeciesEntryReviewRole [not null]
  note text
  created_at timestamp [not null, default: 'now']

  indexes {
    (species_entry_id, user_id, role) [unique, name: 'uq_species_entry_review_species_entry_id']
  }

  Note: 'Store explicit human review or curation events for species entries.'
}

Table submission {
  id bigint [pk, not null]
  created_by bigint [not null, ref: > app_user.id]
  submission_kind SubmissionKind [not null]
  source_kind SubmissionSourceKind [not null, default: 'api']
  upload_job_id uuid [ref: > upload_job.id]
  status SubmissionStatus [not null, default: 'pending']
  title string
  summary text
  submitted_at timestamp [not null, default: 'now']
  approved_at timestamp
  approved_by bigint [ref: > app_user.id]
  rejected_at timestamp
  rejected_by bigint [ref: > app_user.id]
  rejection_reason text
  correction_due_at timestamp
  supersedes_submission_id bigint [ref: > submission.id]
  llm_precheck_label SubmissionPrecheckLabel
  llm_precheck_summary text
  llm_precheck_model string
  llm_precheck_at timestamp
  created_at timestamp [not null, default: 'now']

  indexes {
    (status, created_at) [name: 'ix_submission_status_created_at']
    created_by [name: 'ix_submission_created_by']
    upload_job_id [name: 'ix_submission_upload_job_id']
  }

  checks {
    `(status <> 'approved') OR (approved_by IS NOT NULL AND approved_by <> created_by)` [name: 'ck_submission_submission_approver_not_creator']
    `(status <> 'rejected') OR (rejected_by IS NOT NULL AND rejected_by <> created_by)` [name: 'ck_submission_submission_rejecter_not_creator']
    `(status <> 'rejected') OR (rejection_reason IS NOT NULL)` [name: 'ck_submission_submission_rejected_requires_reason']
  }

  Note: 'One user contribution event tracked for moderation and publication.'
}

Table thermo {
  id bigint [pk, not null]
  species_entry_id bigint [not null, ref: > species_entry.id]
  scientific_origin ScientificOriginKind [not null]
  literature_id bigint [ref: > literature.id]
  workflow_tool_release_id bigint [ref: > workflow_tool_release.id]
  software_release_id bigint [ref: > software_release.id]
  h298_kj_mol double
  s298_j_mol_k double
  h298_uncertainty_kj_mol double
  s298_uncertainty_j_mol_k double
  tmin_k double
  tmax_k double
  note text
  created_at timestamp [not null, default: 'now']
  created_by bigint [ref: > app_user.id]

  checks {
    `tmin_k IS NULL OR tmax_k IS NULL OR tmin_k <= tmax_k` [name: 'ck_thermo_tmin_le_tmax']
    `h298_uncertainty_kj_mol IS NULL OR h298_uncertainty_kj_mol >= 0` [name: 'ck_thermo_h298_uncertainty_ge_0']
    `tmin_k IS NULL OR tmin_k > 0` [name: 'ck_thermo_tmin_k_gt_0']
    `tmax_k IS NULL OR tmax_k > 0` [name: 'ck_thermo_tmax_k_gt_0']
    `s298_uncertainty_j_mol_k IS NULL OR s298_uncertainty_j_mol_k >= 0` [name: 'ck_thermo_s298_uncertainty_ge_0']
  }

  Note: 'Thermochemistry records for a species entry.'
}

Table transport {
  id bigint [pk, not null]
  species_entry_id bigint [not null, ref: > species_entry.id]
  scientific_origin ScientificOriginKind [not null]
  literature_id bigint [ref: > literature.id]
  software_release_id bigint [ref: > software_release.id]
  workflow_tool_release_id bigint [ref: > workflow_tool_release.id]
  sigma_angstrom double
  epsilon_over_k_k double
  dipole_debye double
  polarizability_angstrom3 double
  rotational_relaxation double
  note text
  created_at timestamp [not null, default: 'now']
  created_by bigint [ref: > app_user.id]

  checks {
    `rotational_relaxation IS NULL OR rotational_relaxation >= 0` [name: 'ck_transport_rotational_relaxation_ge_0']
    `sigma_angstrom IS NULL OR sigma_angstrom > 0` [name: 'ck_transport_sigma_angstrom_gt_0']
    `epsilon_over_k_k IS NULL OR epsilon_over_k_k > 0` [name: 'ck_transport_epsilon_over_k_k_gt_0']
    `(sigma_angstrom IS NULL AND epsilon_over_k_k IS NULL) OR (sigma_angstrom IS NOT NULL AND epsilon_over_k_k IS NOT NULL)` [name: 'ck_transport_lj_pair_both_or_neither']
  }

  Note: 'Transport properties attached to a species entry.'
}

Table conformer_observation {
  id bigint [pk, not null]
  conformer_group_id bigint [not null, ref: > conformer_group.id]
  assignment_scheme_id bigint [ref: > conformer_assignment_scheme.id]
  scientific_origin ScientificOriginKind [not null, default: 'computed']
  note text
  torsion_fingerprint_json jsonb
  created_at timestamp [not null, default: 'now']
  created_by bigint [ref: > app_user.id]

  indexes {
    conformer_group_id [name: 'ix_conformer_observation_conformer_group_id']
  }

  Note: 'Store one provenance-bearing conformer observation assigned to a basin.'
}

Table conformer_selection {
  id bigint [pk, not null]
  conformer_group_id bigint [not null, ref: > conformer_group.id]
  assignment_scheme_id bigint [ref: > conformer_assignment_scheme.id]
  selection_kind ConformerSelectionKind [not null]
  note text
  created_at timestamp [not null, default: 'now']
  created_by bigint [ref: > app_user.id]

  indexes {
    (conformer_group_id, assignment_scheme_id, selection_kind) [unique, name: 'uq_conformer_selection_conformer_group_id']
  }

  Note: 'Store explicit workflow, curation, or UI selections for conformer groups.'
}

Table kinetics {
  id bigint [pk, not null]
  reaction_entry_id bigint [not null, ref: > reaction_entry.id]
  scientific_origin ScientificOriginKind [not null]
  model_kind KineticsModelKind [not null, default: 'modified_arrhenius']
  literature_id bigint [ref: > literature.id]
  workflow_tool_release_id bigint [ref: > workflow_tool_release.id]
  software_release_id bigint [ref: > software_release.id]
  a double
  a_units ArrheniusAUnits
  n double
  ea_kj_mol double
  a_uncertainty double
  a_uncertainty_kind KineticsUncertaintyKind
  n_uncertainty double
  ea_uncertainty_kj_mol double
  tmin_k double
  tmax_k double
  degeneracy double
  tunneling_model text
  note text
  created_at timestamp [not null, default: 'now']
  created_by bigint [ref: > app_user.id]

  checks {
    `a_uncertainty_kind <> 'multiplicative' OR a_uncertainty >= 1.0` [name: 'ck_kinetics_a_uncertainty_multiplicative_ge_1']
    `tmin_k IS NULL OR tmax_k IS NULL OR tmin_k <= tmax_k` [name: 'ck_kinetics_tmin_le_tmax']
    `tmin_k IS NULL OR tmin_k > 0` [name: 'ck_kinetics_tmin_k_gt_0']
    `(a_uncertainty IS NULL) = (a_uncertainty_kind IS NULL)` [name: 'ck_kinetics_a_uncertainty_kind_required_with_value']
    `tmax_k IS NULL OR tmax_k > 0` [name: 'ck_kinetics_tmax_k_gt_0']
  }

  Note: 'Kinetics records attached to a reaction entry.'
}

Table network_reaction {
  network_id bigint [not null, ref: > network.id]
  reaction_entry_id bigint [not null, ref: > reaction_entry.id]

  indexes {
    (network_id, reaction_entry_id) [pk]
  }

  Note: 'Links a network to a reaction entry.'
}

Table network_solve {
  id bigint [pk, not null]
  network_id bigint [not null, ref: > network.id]
  literature_id bigint [ref: > literature.id]
  software_release_id bigint [ref: > software_release.id]
  workflow_tool_release_id bigint [ref: > workflow_tool_release.id]
  me_method text
  interpolation_model text
  grain_size_cm_inv double
  grain_count int
  emax_kj_mol double
  tmin_k double
  tmax_k double
  pmin_bar double
  pmax_bar double
  note text
  created_at timestamp [not null, default: 'now']
  created_by bigint [ref: > app_user.id]

  checks {
    `grain_count IS NULL OR grain_count >= 1` [name: 'ck_network_solve_grain_count_ge_1']
    `tmin_k IS NULL OR tmin_k > 0` [name: 'ck_network_solve_tmin_k_gt_0']
    `pmax_bar IS NULL OR pmax_bar > 0` [name: 'ck_network_solve_pmax_bar_gt_0']
    `tmax_k IS NULL OR tmax_k > 0` [name: 'ck_network_solve_tmax_k_gt_0']
    `tmin_k IS NULL OR tmax_k IS NULL OR tmin_k <= tmax_k` [name: 'ck_network_solve_tmin_le_tmax']
    `pmin_bar IS NULL OR pmax_bar IS NULL OR pmin_bar <= pmax_bar` [name: 'ck_network_solve_pmin_le_pmax']
    `pmin_bar IS NULL OR pmin_bar > 0` [name: 'ck_network_solve_pmin_bar_gt_0']
  }

  Note: 'One master-equation solution for a reaction network.'
}

Table network_species {
  network_id bigint [not null, ref: > network.id]
  species_entry_id bigint [not null, ref: > species_entry.id]
  role NetworkSpeciesRole [not null]

  indexes {
    (network_id, role, species_entry_id) [pk]
  }

  Note: 'Links a network to a species entry with a role.'
}

Table network_state {
  id bigint [pk, not null]
  network_id bigint [not null, ref: > network.id]
  kind NetworkStateKind [not null]
  composition_hash varchar(64) [not null]
  label text

  indexes {
    (network_id, composition_hash) [unique, name: 'uq_network_state_network_id']
  }

  Note: 'A macroscopic state in a reaction network (well or bimolecular channel).'
}

Table reaction_entry_structure_participant {
  id bigint [pk, not null]
  reaction_entry_id bigint [not null, ref: > reaction_entry.id]
  species_entry_id bigint [not null, ref: > species_entry.id]
  role ReactionRole [not null]
  participant_index int [not null]
  note text
  created_at timestamp [not null, default: 'now']
  created_by bigint [ref: > app_user.id]

  indexes {
    (reaction_entry_id, role, participant_index) [unique, name: 'uq_reaction_entry_structure_participant_reaction_entry_id']
  }

  checks {
    `participant_index >= 1` [name: 'ck_reaction_entry_structure_participant_participant_index_ge_1']
  }
}

Table record_review {
  id bigint [pk, not null]
  record_type SubmissionRecordType [not null]
  record_id bigint [not null]
  status RecordReviewStatus [not null, default: 'not_reviewed']
  submission_id bigint [ref: > submission.id]
  reviewed_by bigint [ref: > app_user.id]
  reviewed_at timestamp
  note text
  created_at timestamp [not null, default: 'now']
  created_by bigint [ref: > app_user.id]

  indexes {
    (status, record_type) [name: 'ix_record_review_status_record_type']
    submission_id [name: 'ix_record_review_submission_id']
    (record_type, record_id) [unique, name: 'uq_record_review_record']
  }

  checks {
    `(status NOT IN ('approved', 'rejected', 'deprecated')) OR (reviewed_by IS NOT NULL AND reviewed_at IS NOT NULL)` [name: 'ck_record_review_record_review_terminal_requires_reviewer']
  }

  Note: 'Current review/trust state for one scientific record.'
}

Table statmech {
  id bigint [pk, not null]
  species_entry_id bigint [not null, ref: > species_entry.id]
  scientific_origin ScientificOriginKind [not null]
  literature_id bigint [ref: > literature.id]
  workflow_tool_release_id bigint [ref: > workflow_tool_release.id]
  software_release_id bigint [ref: > software_release.id]
  external_symmetry int
  point_group text
  is_linear boolean
  rigid_rotor_kind RigidRotorKind
  statmech_treatment StatmechTreatmentKind
  frequency_scale_factor_id bigint [ref: > frequency_scale_factor.id]
  uses_projected_frequencies boolean
  note text
  created_at timestamp [not null, default: 'now']
  created_by bigint [ref: > app_user.id]

  checks {
    `external_symmetry IS NULL OR external_symmetry >= 1` [name: 'ck_statmech_external_symmetry_ge_1']
  }

  Note: 'Statistical mechanics interpretation layer for a species entry.'
}

Table submission_audit_event {
  id bigint [pk, not null]
  submission_id bigint [not null, ref: > submission.id]
  created_at timestamp [not null, default: 'now']
  actor_user_id bigint [ref: > app_user.id]
  actor_kind SubmissionActorKind [not null]
  event_kind SubmissionAuditEventKind [not null]
  from_status SubmissionStatus
  to_status SubmissionStatus
  reason text
  summary text
  details_json jsonb
  related_submission_id bigint [ref: > submission.id]

  indexes {
    submission_id [name: 'ix_submission_audit_event_submission_id']
    event_kind [name: 'ix_submission_audit_event_event_kind']
  }

  Note: 'Append-only moderation/lifecycle event for a submission.'
}

Table submission_record_link {
  id bigint [pk, not null]
  submission_id bigint [not null, ref: > submission.id]
  record_type SubmissionRecordType [not null]
  record_id bigint [not null]
  role string
  created_at timestamp [not null, default: 'now']

  indexes {
    submission_id [name: 'ix_submission_record_link_submission_id']
    (record_type, record_id) [name: 'ix_submission_record_link_record']
    (submission_id, record_type, record_id, role) [unique, name: 'uq_submission_record_link_identity']
  }

  Note: 'Lightweight mapping from a submission to one scientific record it'
}

Table thermo_nasa {
  thermo_id bigint [pk, not null, ref: > thermo.id]
  t_low double
  t_mid double
  t_high double
  a1 double
  a2 double
  a3 double
  a4 double
  a5 double
  a6 double
  a7 double
  b1 double
  b2 double
  b3 double
  b4 double
  b5 double
  b6 double
  b7 double

  checks {
    `t_low IS NULL OR t_low > 0` [name: 'ck_thermo_nasa_t_low_gt_0']
    `t_mid IS NULL OR t_high IS NULL OR t_high > t_mid` [name: 'ck_thermo_nasa_t_high_gt_t_mid']
    `
            (
                t_low IS NULL
                AND t_mid IS NULL
                AND t_high IS NULL
            )
            OR
            (
                t_low IS NOT NULL
                AND t_mid IS NOT NULL
                AND t_high IS NOT NULL
            )
            ` [name: 'ck_thermo_nasa_temperature_bounds_all_or_none']
    `t_low IS NULL OR t_mid IS NULL OR t_mid > t_low` [name: 'ck_thermo_nasa_t_mid_gt_t_low']
  }

  Note: 'NASA polynomial coefficients for a thermo record.'
}

Table thermo_point {
  thermo_id bigint [not null, ref: > thermo.id]
  temperature_k double [not null]
  cp_j_mol_k double
  h_kj_mol double
  s_j_mol_k double
  g_kj_mol double

  indexes {
    (temperature_k, thermo_id) [pk]
  }

  Note: 'Tabulated thermo values at a specific temperature.'
}

Table transition_state {
  id bigint [pk, not null]
  reaction_entry_id bigint [not null, ref: > reaction_entry.id]
  label text
  note text
  created_at timestamp [not null, default: 'now']
  created_by bigint [ref: > app_user.id]

  Note: 'Reaction-channel-level transition-state concept.'
}

Table network_channel {
  id bigint [pk, not null]
  network_id bigint [not null, ref: > network.id]
  source_state_id bigint [not null, ref: > network_state.id]
  sink_state_id bigint [not null, ref: > network_state.id]
  kind NetworkChannelKind [not null]

  indexes {
    (network_id, source_state_id, sink_state_id) [unique, name: 'uq_network_channel_network_id']
  }

  checks {
    `source_state_id <> sink_state_id` [name: 'ck_network_channel_source_ne_sink']
  }

  Note: 'A directed phenomenological channel between two network states.'
}

Table network_solve_bath_gas {
  solve_id bigint [not null, ref: > network_solve.id]
  species_entry_id bigint [not null, ref: > species_entry.id]
  mole_fraction double [not null]

  indexes {
    (solve_id, species_entry_id) [pk]
  }

  checks {
    `mole_fraction > 0 AND mole_fraction <= 1` [name: 'ck_network_solve_bath_gas_mole_fraction_range']
  }

  Note: 'Bath gas composition for one network solve.'
}

Table network_solve_energy_transfer {
  id bigint [pk, not null]
  solve_id bigint [not null, ref: > network_solve.id]
  model text
  alpha0_cm_inv double
  t_exponent double
  t_ref_k double
  note text

  Note: 'Energy transfer model parameters for one network solve.'
}

Table network_state_participant {
  state_id bigint [not null, ref: > network_state.id]
  species_entry_id bigint [not null, ref: > species_entry.id]
  stoichiometry int [not null, default: '1']

  indexes {
    (species_entry_id, state_id) [pk]
  }

  checks {
    `stoichiometry >= 1` [name: 'ck_network_state_participant_stoichiometry_ge_1']
  }

  Note: 'Species composition of a network state.'
}

Table transition_state_entry {
  id bigint [pk, not null]
  transition_state_id bigint [not null, ref: > transition_state.id]
  charge int [not null]
  multiplicity int [not null]
  mol mol
  unmapped_smiles text
  status TransitionStateEntryStatus [not null, default: 'optimized']
  created_at timestamp [not null, default: 'now']
  created_by bigint [ref: > app_user.id]

  checks {
    `multiplicity >= 1` [name: 'ck_transition_state_entry_multiplicity_ge_1']
  }

  Note: 'One candidate transition-state geometry family member under a TS concept.'
}

Table calculation {
  id bigint [pk, not null]
  type CalculationType [not null]
  quality CalculationQuality [not null, default: 'raw']
  species_entry_id bigint [ref: > species_entry.id]
  transition_state_entry_id bigint [ref: > transition_state_entry.id]
  software_release_id bigint [ref: > software_release.id]
  workflow_tool_release_id bigint [ref: > workflow_tool_release.id]
  lot_id bigint [ref: > level_of_theory.id]
  literature_id bigint [ref: > literature.id]
  conformer_observation_id bigint [ref: > conformer_observation.id]
  parameters_json jsonb
  parameters_parser_version text
  parameters_extracted_at timestamp
  created_at timestamp [not null, default: 'now']
  created_by bigint [ref: > app_user.id]

  checks {
    `
                (
                    transition_state_entry_id IS NOT NULL
                    AND species_entry_id IS NULL
                )
                OR
                (
                    transition_state_entry_id IS NULL
                    AND species_entry_id IS NOT NULL
                )
                ` [name: 'ck_calculation_one_owner']
  }

  Note: 'Computational record with one scientific owner and an optional observation anchor.'
}

Table network_kinetics {
  id bigint [pk, not null]
  channel_id bigint [not null, ref: > network_channel.id]
  solve_id bigint [not null, ref: > network_solve.id]
  model_kind NetworkKineticsModelKind [not null]
  tmin_k double
  tmax_k double
  pmin_bar double
  pmax_bar double
  rate_units ArrheniusAUnits
  pressure_units PressureUnit
  temperature_units TemperatureUnit
  stores_log10_k boolean
  note text
  created_at timestamp [not null, default: 'now']

  checks {
    `tmin_k IS NULL OR tmax_k IS NULL OR tmin_k <= tmax_k` [name: 'ck_network_kinetics_tmin_le_tmax']
    `pmin_bar IS NULL OR pmax_bar IS NULL OR pmin_bar <= pmax_bar` [name: 'ck_network_kinetics_pmin_le_pmax']
    `pmax_bar IS NULL OR pmax_bar > 0` [name: 'ck_network_kinetics_pmax_bar_gt_0']
    `pmin_bar IS NULL OR pmin_bar > 0` [name: 'ck_network_kinetics_pmin_bar_gt_0']
    `tmin_k IS NULL OR tmin_k > 0` [name: 'ck_network_kinetics_tmin_k_gt_0']
    `tmax_k IS NULL OR tmax_k > 0` [name: 'ck_network_kinetics_tmax_k_gt_0']
  }

  Note: 'One fitted phenomenological k(T,P) for a channel from a specific solve.'
}

Table applied_energy_correction {
  id bigint [pk, not null]
  target_species_entry_id bigint [ref: > species_entry.id]
  target_reaction_entry_id bigint [ref: > reaction_entry.id]
  target_transition_state_entry_id bigint [ref: > transition_state_entry.id]
  source_conformer_observation_id bigint [ref: > conformer_observation.id]
  source_calculation_id bigint [ref: > calculation.id]
  scheme_id bigint [ref: > energy_correction_scheme.id]
  frequency_scale_factor_id bigint [ref: > frequency_scale_factor.id]
  application_role EnergyCorrectionApplicationRole [not null]
  value double [not null]
  value_unit EnergyUnit [not null]
  temperature_k double
  note text
  created_at timestamp [not null, default: 'now']
  created_by bigint [ref: > app_user.id]

  indexes {
    (target_species_entry_id, target_reaction_entry_id, target_transition_state_entry_id, source_conformer_observation_id, scheme_id, frequency_scale_factor_id, application_role, temperature_k, source_calculation_id) [unique, name: 'uq_applied_energy_correction_dedup']
  }

  checks {
    `temperature_k IS NULL OR temperature_k > 0` [name: 'ck_applied_energy_correction_temperature_k_gt_0']
    `num_nonnulls(target_species_entry_id, target_reaction_entry_id, target_transition_state_entry_id) = 1` [name: 'ck_applied_energy_correction_exactly_one_target']
    `num_nonnulls(scheme_id, frequency_scale_factor_id) = 1` [name: 'ck_applied_energy_correction_exactly_one_provenance_source']
  }

  Note: 'One energy correction applied to a specific entry.'
}

Table calc_freq_result {
  calculation_id bigint [pk, not null, ref: > calculation.id]
  n_imag int
  imag_freq_cm1 double
  zpe_hartree double
  zpe_uncertainty_hartree double
}

Table calc_geometry_validation {
  calculation_id bigint [pk, not null, ref: > calculation.id]
  input_geometry_id bigint [ref: > geometry.id]
  output_geometry_id bigint [ref: > geometry.id]
  species_smiles text [not null]
  is_isomorphic boolean [not null]
  rmsd double
  atom_mapping jsonb
  n_mappings int
  validation_status ValidationStatus [not null]
  validation_reason text
  rmsd_warning_threshold double
  created_at timestamp [not null, default: 'now']

  Note: 'Result of validating a calculation\'s output geometry against species identity.'
}

Table calc_irc_point {
  calculation_id bigint [not null, ref: > calculation.id]
  point_index int [not null]
  direction IRCDirection
  is_ts boolean [not null]
  reaction_coordinate double
  electronic_energy_hartree double
  relative_energy_kj_mol double
  max_gradient double
  rms_gradient double
  geometry_id bigint [ref: > geometry.id]
  note text

  indexes {
    (calculation_id, point_index) [pk]
  }

  checks {
    `point_index >= 0` [name: 'ck_calc_irc_point_point_index_ge_0']
  }

  Note: 'One sampled point on an IRC path.'
}

Table calc_irc_result {
  calculation_id bigint [pk, not null, ref: > calculation.id]
  direction IRCDirection [not null]
  has_forward boolean [not null]
  has_reverse boolean [not null]
  ts_point_index int
  point_count int
  zero_energy_reference_hartree double
  note text

  checks {
    `point_count IS NULL OR point_count >= 0` [name: 'ck_calc_irc_result_point_count_ge_0']
  }

  Note: 'IRC-level metadata for an IRC calculation.'
}

Table calc_opt_result {
  calculation_id bigint [pk, not null, ref: > calculation.id]
  converged boolean
  n_steps int
  final_energy_hartree double

  checks {
    `n_steps IS NULL OR n_steps >= 0` [name: 'ck_calc_opt_result_n_steps_ge_0']
  }
}

Table calc_path_search_point {
  calculation_id bigint [not null, ref: > calculation.id]
  point_index int [not null]
  electronic_energy_hartree double
  relative_energy_kj_mol double
  path_coordinate double
  max_force double
  rms_force double
  max_gradient double
  rms_gradient double
  is_ts_guess boolean [not null]
  is_climbing_image boolean [not null]
  geometry_id bigint [ref: > geometry.id]
  note text

  indexes {
    (calculation_id, point_index) [pk]
  }

  checks {
    `point_index >= 0` [name: 'ck_calc_path_search_point_point_index_ge_0']
  }

  Note: 'One sampled point on a path-search calculation\'s reaction path.'
}

Table calc_path_search_result {
  calculation_id bigint [pk, not null, ref: > calculation.id]
  method PathSearchMethod [not null]
  is_double_ended boolean
  converged boolean
  n_points int
  selected_ts_point_index int
  climbing_image_index int
  source_endpoint_count int
  zero_energy_reference_hartree double
  note text

  checks {
    `climbing_image_index IS NULL OR climbing_image_index >= 0` [name: 'ck_calc_path_search_result_climbing_image_index_ge_0']
    `selected_ts_point_index IS NULL OR selected_ts_point_index >= 0` [name: 'ck_calc_path_search_result_selected_ts_point_index_ge_0']
    `source_endpoint_count IS NULL OR source_endpoint_count >= 1` [name: 'ck_calc_path_search_result_source_endpoint_count_ge_1']
    `n_points IS NULL OR n_points >= 1` [name: 'ck_calc_path_search_result_n_points_ge_1']
  }

  Note: 'Path-search-level metadata for a calculation that explored a'
}

Table calc_scan_coordinate {
  calculation_id bigint [not null, ref: > calculation.id]
  coordinate_index int [not null]
  coordinate_kind ScanCoordinateKind [not null]
  atom1_index int [not null]
  atom2_index int [not null]
  atom3_index int
  atom4_index int
  step_count int
  step_size double
  start_value double
  end_value double
  value_unit CoordinateUnit
  resolution_degrees int
  symmetry_number int

  indexes {
    (calculation_id, coordinate_index) [pk]
  }

  checks {
    `atom2_index >= 1` [name: 'ck_calc_scan_coordinate_atom2_index_ge_1']
    `atom3_index IS NULL OR atom3_index >= 1` [name: 'ck_calc_scan_coordinate_atom3_index_ge_1']
    `
            CASE coordinate_kind
                WHEN 'bond' THEN atom3_index IS NULL AND atom4_index IS NULL
                WHEN 'angle' THEN atom3_index IS NOT NULL AND atom4_index IS NULL
                ELSE atom3_index IS NOT NULL AND atom4_index IS NOT NULL
            END
            ` [name: 'ck_calc_scan_coordinate_coordinate_arity_matches_kind']
    `atom1_index >= 1` [name: 'ck_calc_scan_coordinate_atom1_index_ge_1']
    `step_count IS NULL OR step_count >= 1` [name: 'ck_calc_scan_coordinate_step_count_ge_1']
    `symmetry_number IS NULL OR symmetry_number >= 1` [name: 'ck_calc_scan_coordinate_symmetry_number_ge_1']
    `atom4_index IS NULL OR atom4_index >= 1` [name: 'ck_calc_scan_coordinate_atom4_index_ge_1']
    `resolution_degrees IS NULL OR resolution_degrees >= 1` [name: 'ck_calc_scan_coordinate_resolution_degrees_ge_1']
    `coordinate_index >= 1` [name: 'ck_calc_scan_coordinate_coordinate_index_ge_1']
  }

  Note: 'Definition of one scanned internal coordinate.'
}

Table calc_scan_point {
  calculation_id bigint [not null, ref: > calculation.id]
  point_index int [not null]
  electronic_energy_hartree double
  relative_energy_kj_mol double
  geometry_id bigint [ref: > geometry.id]
  note text

  indexes {
    (calculation_id, point_index) [pk]
  }

  checks {
    `point_index >= 1` [name: 'ck_calc_scan_point_point_index_ge_1']
  }

  Note: 'One sampled point on a scan surface.'
}

Table calc_scan_result {
  calculation_id bigint [pk, not null, ref: > calculation.id]
  dimension int [not null]
  is_relaxed boolean
  zero_energy_reference_hartree double
  note text

  checks {
    `dimension >= 1` [name: 'ck_calc_scan_result_dimension_ge_1']
  }

  Note: 'Scan-level metadata for a scan calculation.'
}

Table calc_sp_result {
  calculation_id bigint [pk, not null, ref: > calculation.id]
  electronic_energy_hartree double
  electronic_energy_uncertainty_hartree double
}

Table calculation_artifact {
  id bigint [pk, not null]
  calculation_id bigint [not null, ref: > calculation.id]
  kind ArtifactKind [not null]
  uri text [not null]
  sha256 varchar(64)
  bytes bigint
  filename text [not null]
  note text
  created_at timestamp [not null, default: 'now']
  created_by bigint [ref: > app_user.id]

  Note: 'Append-only artifact metadata: bytes-on-S3 plus minimal upload context.'
}

Table calculation_constraint {
  calculation_id bigint [not null, ref: > calculation.id]
  constraint_index int [not null]
  constraint_kind ConstraintKind [not null]
  atom1_index int [not null]
  atom2_index int
  atom3_index int
  atom4_index int
  target_value double

  indexes {
    (calculation_id, constraint_index) [pk]
  }

  checks {
    `atom1_index >= 1` [name: 'ck_calculation_constraint_atom1_index_ge_1']
    `atom4_index IS NULL OR atom4_index >= 1` [name: 'ck_calculation_constraint_atom4_index_ge_1']
    `atom2_index IS NULL OR atom2_index >= 1` [name: 'ck_calculation_constraint_atom2_index_ge_1']
    `
            CASE constraint_kind
                WHEN 'cartesian_atom' THEN atom2_index IS NULL AND atom3_index IS NULL AND atom4_index IS NULL
                WHEN 'bond' THEN atom2_index IS NOT NULL AND atom3_index IS NULL AND atom4_index IS NULL
                WHEN 'angle' THEN atom2_index IS NOT NULL AND atom3_index IS NOT NULL AND atom4_index IS NULL
                ELSE atom2_index IS NOT NULL AND atom3_index IS NOT NULL AND atom4_index IS NOT NULL
            END
            ` [name: 'ck_calculation_constraint_constraint_arity_matches_kind']
    `constraint_index >= 1` [name: 'ck_calculation_constraint_constraint_index_ge_1']
    `atom3_index IS NULL OR atom3_index >= 1` [name: 'ck_calculation_constraint_atom3_index_ge_1']
  }

  Note: 'Geometric constraint applied to a calculation.'
}

Table calculation_dependency {
  parent_calculation_id bigint [not null, ref: > calculation.id]
  child_calculation_id bigint [not null, ref: > calculation.id]
  dependency_role CalculationDependencyRole [not null]

  indexes {
    (child_calculation_id, parent_calculation_id) [pk]
    child_calculation_id [unique, name: 'uq_calculation_dependency_child_calculation_id_scan_parent']
    child_calculation_id [unique, name: 'uq_calculation_dependency_child_calculation_id_single_point_on']
    child_calculation_id [unique, name: 'uq_calculation_dependency_child_calculation_id_optimized_from']
    child_calculation_id [unique, name: 'uq_calculation_dependency_child_calculation_id_freq_on']
  }

  checks {
    `parent_calculation_id <> child_calculation_id` [name: 'ck_calculation_dependency_not_self']
  }

  Note: 'Directed dependency edge between two calculations.'
}

Table calculation_input_geometry {
  calculation_id bigint [not null, ref: > calculation.id]
  geometry_id bigint [not null, ref: > geometry.id]
  input_order int [not null, default: '1']

  indexes {
    (calculation_id, input_order) [pk]
    (calculation_id, geometry_id) [unique, name: 'uq_calculation_input_geometry_calculation_id']
  }

  checks {
    `input_order >= 1` [name: 'ck_calculation_input_geometry_input_order_ge_1']
  }

  Note: 'Ordered input-geometry link table for a calculation.'
}

Table calculation_output_geometry {
  calculation_id bigint [not null, ref: > calculation.id]
  geometry_id bigint [not null, ref: > geometry.id]
  output_order int [not null]
  role CalculationGeometryRole

  indexes {
    (calculation_id, output_order) [pk]
    (calculation_id, geometry_id) [unique, name: 'uq_calculation_output_geometry_calculation_id']
  }

  checks {
    `output_order >= 1` [name: 'ck_calculation_output_geometry_output_order_ge_1']
  }
}

Table calculation_parameter {
  id bigint [pk, not null]
  calculation_id bigint [not null, ref: > calculation.id]
  raw_key text [not null]
  canonical_key text [ref: > calculation_parameter_vocab.canonical_key]
  raw_value text [not null]
  canonical_value text
  section text
  value_type text
  unit text
  parameter_index int
  source ParameterSource [not null, default: 'upload']
  parser_version text
  created_at timestamp [not null, default: 'now']

  indexes {
    (raw_key, section) [name: 'ix_calculation_parameter_raw_key_section']
    calculation_id [name: 'ix_calculation_parameter_calculation_id']
    (canonical_key, canonical_value) [name: 'ix_calculation_parameter_canonical_key_value']
    canonical_key [name: 'ix_calculation_parameter_canonical_key']
  }

  checks {
    `parameter_index IS NULL OR parameter_index >= 0` [name: 'ck_calculation_parameter_parameter_index_ge_0']
  }

  Note: 'EAV-style parsed parameter from an ESS calculation.'
}

Table kinetics_source_calculation {
  kinetics_id bigint [not null, ref: > kinetics.id]
  calculation_id bigint [not null, ref: > calculation.id]
  role KineticsCalculationRole [not null]

  indexes {
    (calculation_id, kinetics_id, role) [pk]
  }

  Note: 'Links kinetics records to supporting calculations by role.'
}

Table network_kinetics_chebyshev {
  network_kinetics_id bigint [pk, not null, ref: > network_kinetics.id]
  n_temperature int [not null]
  n_pressure int [not null]
  coefficients jsonb [not null]

  checks {
    `n_pressure >= 1` [name: 'ck_network_kinetics_chebyshev_n_pressure_ge_1']
    `n_temperature >= 1` [name: 'ck_network_kinetics_chebyshev_n_temperature_ge_1']
  }

  Note: 'Chebyshev polynomial coefficients for a network kinetics record.'
}

Table network_kinetics_plog {
  network_kinetics_id bigint [not null, ref: > network_kinetics.id]
  pressure_bar double [not null]
  entry_index int [not null, default: '1']
  a double [not null]
  a_units ArrheniusAUnits
  n double [not null]
  ea_kj_mol double [not null]

  indexes {
    (entry_index, network_kinetics_id, pressure_bar) [pk]
  }

  checks {
    `pressure_bar > 0` [name: 'ck_network_kinetics_plog_pressure_bar_gt_0']
    `entry_index >= 1` [name: 'ck_network_kinetics_plog_entry_index_ge_1']
  }

  Note: 'One PLOG entry: Arrhenius parameters at a discrete pressure.'
}

Table network_kinetics_point {
  network_kinetics_id bigint [not null, ref: > network_kinetics.id]
  temperature_k double [not null]
  pressure_bar double [not null]
  rate_value double [not null]

  indexes {
    (network_kinetics_id, pressure_bar, temperature_k) [pk]
  }

  checks {
    `pressure_bar > 0` [name: 'ck_network_kinetics_point_pressure_bar_gt_0']
    `temperature_k > 0` [name: 'ck_network_kinetics_point_temperature_k_gt_0']
  }

  Note: 'One tabulated k(T,P) data point.'
}

Table network_solve_source_calculation {
  solve_id bigint [not null, ref: > network_solve.id]
  calculation_id bigint [not null, ref: > calculation.id]
  role NetworkSolveCalculationRole [not null]

  indexes {
    (calculation_id, role, solve_id) [pk]
  }

  Note: 'Links a network solve to supporting calculations by role.'
}

Table statmech_source_calculation {
  statmech_id bigint [not null, ref: > statmech.id]
  calculation_id bigint [not null, ref: > calculation.id]
  role StatmechCalculationRole [not null]

  indexes {
    (calculation_id, role, statmech_id) [pk]
  }

  Note: 'Links statmech records to source calculations by role.'
}

Table statmech_torsion {
  id bigint [pk, not null]
  statmech_id bigint [not null, ref: > statmech.id]
  torsion_index int [not null]
  symmetry_number int
  treatment_kind TorsionTreatmentKind
  dimension int [not null]
  top_description text
  invalidated_reason text
  note text
  source_scan_calculation_id bigint [ref: > calculation.id]

  indexes {
    (statmech_id, torsion_index) [unique, name: 'uq_statmech_torsion_statmech_id']
  }

  checks {
    `symmetry_number IS NULL OR symmetry_number >= 1` [name: 'ck_statmech_torsion_symmetry_number_ge_1']
    `torsion_index >= 1` [name: 'ck_statmech_torsion_torsion_index_ge_1']
    `dimension >= 1` [name: 'ck_statmech_torsion_dimension_ge_1']
  }

  Note: 'Stores one torsion associated with a statmech record.'
}

Table thermo_source_calculation {
  thermo_id bigint [not null, ref: > thermo.id]
  calculation_id bigint [not null, ref: > calculation.id]
  role ThermoCalculationRole [not null]

  indexes {
    (calculation_id, role, thermo_id) [pk]
  }

  Note: 'Links thermo records to supporting calculations by role.'
}

Table transport_source_calculation {
  transport_id bigint [not null, ref: > transport.id]
  calculation_id bigint [not null, ref: > calculation.id]
  role TransportCalculationRole [not null]

  indexes {
    (calculation_id, role, transport_id) [pk]
  }

  Note: 'Links transport records to supporting calculations by role.'
}

Table applied_energy_correction_component {
  id bigint [pk, not null]
  applied_correction_id bigint [not null, ref: > applied_energy_correction.id]
  component_kind AppliedCorrectionComponentKind [not null]
  key text [not null]
  multiplicity int [not null, default: '1']
  parameter_value double [not null]
  contribution_value double [not null]

  checks {
    `multiplicity >= 1` [name: 'ck_applied_energy_correction_component_multiplicity_ge_1']
  }

  Note: 'Per-component breakdown of an applied energy correction.'
}

Table calc_scan_point_coordinate_value {
  calculation_id bigint [not null, ref: > calc_scan_coordinate.calculation_id]
  point_index int [not null, ref: > calc_scan_point.point_index]
  coordinate_index int [not null, ref: > calc_scan_coordinate.coordinate_index]
  coordinate_value double [not null]
  value_unit CoordinateUnit

  indexes {
    (calculation_id, coordinate_index, point_index) [pk]
  }

  checks {
    `point_index >= 1` [name: 'ck_calc_scan_point_coordinate_value_point_index_ge_1']
    `coordinate_index >= 1` [name: 'ck_calc_scan_point_coordinate_value_coordinate_index_ge_1']
  }

  Note: 'Coordinate values for one sampled scan point.'
}

Table statmech_torsion_definition {
  torsion_id bigint [not null, ref: > statmech_torsion.id]
  coordinate_index int [not null]
  atom1_index int [not null]
  atom2_index int [not null]
  atom3_index int [not null]
  atom4_index int [not null]

  indexes {
    (coordinate_index, torsion_id) [pk]
  }

  checks {
    `atom3_index >= 1` [name: 'ck_statmech_torsion_definition_atom3_index_ge_1']
    `coordinate_index >= 1` [name: 'ck_statmech_torsion_definition_coordinate_index_ge_1']
    `atom4_index >= 1` [name: 'ck_statmech_torsion_definition_atom4_index_ge_1']
    `atom1_index >= 1` [name: 'ck_statmech_torsion_definition_atom1_index_ge_1']
    `atom2_index >= 1` [name: 'ck_statmech_torsion_definition_atom2_index_ge_1']
  }

  Note: 'Atom indices for a torsional coordinate.'
}

Ref fk_calc_scan_point_coordinate_value_calculation_id_calc_scan_coordinate: calc_scan_point_coordinate_value.(calculation_id, coordinate_index) > calc_scan_coordinate.(calculation_id, coordinate_index)

Ref fk_calc_scan_point_coordinate_value_calculation_id_calc_scan_point: calc_scan_point_coordinate_value.(calculation_id, point_index) > calc_scan_point.(calculation_id, point_index)
