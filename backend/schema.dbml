  ez_isomer
}

enum SubmissionActorKind {
  user
  curator
  admin
  llm
  system
}

enum SubmissionAuditEventKind {
  submission_created
  ingestion_succeeded
  ingestion_failed
  llm_precheck_passed
  llm_precheck_flagged
  curator_approved
  curator_rejected
  correction_window_opened
  correction_uploaded
  submission_superseded
  status_changed
  public_visibility_changed
}

