# ============================================================================
# TCKDB — Local v0 environment
#
# Copy to .env and adjust as needed:
#   cp .env.local.example .env
#
# Local v0 uses the same backend, schema, services, and authentication as
# the hosted deployment.  The values below are deliberately tuned for a
# single-machine developer/lab setup — do not reuse them in production.
# ============================================================================

# -- PostgreSQL (with RDKit cartridge) ---------------------------------------
# Matches the defaults in app/api/config.py so the host-side API/worker
# reach the containerized DB at 127.0.0.1:5432 without overrides.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=tckdb_dev
DB_USER=tckdb
DB_PASSWORD=tckdb
DB_CLIENT_ENCODING=utf8

# Test database (auto-created by pytest, dropped after).  Optional.
# DB_TEST_NAME=tckdb_test

# -- MinIO / S3 artifact storage ---------------------------------------------
# Local v0 uses MinIO via docker-compose.local.yml.  In production set
# S3_ENDPOINT_URL=https://s3.amazonaws.com (or omit) and use real keys.
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=tckdb
S3_SECRET_KEY=tckdb_secret
S3_BUCKET=tckdb-artifacts
S3_REGION=us-east-1

# -- Authentication / registration policy ------------------------------------
# In local mode public registration is enabled by default so a fresh
# instance is self-serve.  Hosted/production deployments should set this
# to ``false`` and seed accounts via scripts/bootstrap_admin.py.
AUTH_ALLOW_OPEN_REGISTRATION=true

# -- Upload worker -----------------------------------------------------------
# The upload pipeline can run inline (in the API process) or as a separate
# worker process.  Local v0 defaults to inline for simplicity; flip this
# to ``false`` and run ``python -m app.workers.upload_worker`` in a
# second terminal if you want isolation.
TCKDB_INLINE_WORKER=true

# -- Backend API binding -----------------------------------------------------
# Used only by the documented uvicorn command — the application code
# does not read these.  Override the host/port if 8000 is taken.
TCKDB_API_HOST=127.0.0.1
TCKDB_API_PORT=8000
