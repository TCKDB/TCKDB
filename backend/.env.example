# ============================================================================
# TCKDB Environment Configuration
#
# Copy this file to .env and adjust values for your setup:
#   cp .env.example .env
#
# The .env file is gitignored — your secrets stay local.
# ============================================================================

# -- PostgreSQL (with RDKit cartridge) --
#
# Host vs container ports: the compose file publishes the DB as
#   127.0.0.1:${DB_PORT:-5432} -> container port 5432
#
# Set DB_HOST/DB_PORT for the *consumer* (host-side Alembic, host-side
# Uvicorn). Inside the container, Postgres always listens on 5432.
#
#   API/Alembic run on the host (the default):
#     DB_HOST=127.0.0.1
#     DB_PORT=<host-published port — e.g. 5432, or 5434 if you bumped
#             it to avoid clashing with a host-installed Postgres>
#
#   API runs inside the same compose network (future containerized API):
#     DB_HOST=db          # the compose service name
#     DB_PORT=5432        # the container port — does not move
#
# See docs/deployment/troubleshooting.md ("host port vs container port")
# if this distinction is unfamiliar.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=tckdb_dev
DB_USER=tckdb
DB_PASSWORD=tckdb
DB_CLIENT_ENCODING=utf8

# Test database (auto-created by pytest, dropped after)
# DB_TEST_NAME=tckdb_test

# -- MinIO / S3 artifact storage --
# Local dev uses MinIO (started via docker compose).
# For production AWS S3, change the endpoint and credentials.
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=tckdb
S3_SECRET_KEY=tckdb_secret
S3_BUCKET=tckdb-artifacts
S3_REGION=us-east-1

# For production AWS S3:
# S3_ENDPOINT_URL=https://s3.amazonaws.com
# S3_ACCESS_KEY=AKIA...
# S3_SECRET_KEY=your-secret-key
# S3_BUCKET=tckdb-artifacts-prod
# S3_REGION=us-east-1
