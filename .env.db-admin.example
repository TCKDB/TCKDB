# TCKDB database operator credentials (HOSTED DEPLOYMENTS ONLY)
#
# Copy to .env.db-admin, replace both passwords, and chmod 600.  Never load
# this file into the API or worker process.  Operators pass it to Docker
# Compose for database bootstrap and source it only while provisioning roles,
# running Alembic, or performing privileged recovery.

# Cluster bootstrap/recovery account.  The PostgreSQL container creates this
# role as a superuser on a fresh volume.  It is not used by TCKDB application
# code and should not own application schema objects after provisioning.
DB_ADMIN_USER=tckdb_admin
DB_ADMIN_PASSWORD=change-me-strong-admin-password

# Non-superuser owner of the TCKDB database, public schema, tables, sequences,
# functions, and application enum/domain types.  Alembic uses this account.
DB_OWNER_USER=tckdb_owner
DB_OWNER_PASSWORD=change-me-strong-owner-password
