# ============================================================================
# TCKDB - Raspberry Pi hosted deployment environment (EXAMPLE / PLACEHOLDERS)
#
# Copy to .env.pi on the Pi and replace every `change-me-*` value:
#   cp .env.pi.example .env.pi
# Do NOT commit the resulting file.
#
# Reference doc: docs/deployment/raspberry_pi_hosted_deployment.md
# Compose file:  docker-compose.pi.yml
#
# This file targets a *hosted* deployment: anonymous scientific reads are
# allowed, but every abuse-control knob is on, docs are off, legacy
# routes require auth, internal IDs are hidden, and the API is reachable
# only via a Cloudflare Tunnel terminating on the Pi.
# ============================================================================

# ----------------------------------------------------------------------------
# PostgreSQL (RDKit cartridge image, native arm64)
# ----------------------------------------------------------------------------
# Bound to 127.0.0.1 only inside docker-compose.pi.yml. Never expose 5432
# on the public interface.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=tckdb
DB_USER=tckdb
DB_PASSWORD=change-me-strong-db-password
DB_CLIENT_ENCODING=utf8

# Postgres session statement_timeout (ms). Belt-and-braces: the doc also
# sets this at the role level via `ALTER ROLE tckdb SET statement_timeout`.
DB_STATEMENT_TIMEOUT_MS=30000

# ----------------------------------------------------------------------------
# MinIO / S3 artifact storage
# ----------------------------------------------------------------------------
# Bound to 127.0.0.1 only. The MinIO console (9001) is NEVER published
# to the tunnel - see docker-compose.pi.yml.
S3_ENDPOINT_URL=http://127.0.0.1:9000
S3_ACCESS_KEY=change-me-s3-access-key
S3_SECRET_KEY=change-me-s3-secret-key
S3_BUCKET=tckdb-artifacts
S3_REGION=us-east-1

# ----------------------------------------------------------------------------
# Hosted abuse-control posture (security phase 1)
# ----------------------------------------------------------------------------
# Master switch for the application-level rate limiter. MUST be true.
RATE_LIMIT_ENABLED=true

# Per-minute budgets. Conservative starting values for a Pi - tune up
# only after observing legitimate-traffic patterns.
RATE_LIMIT_ANON_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=300
RATE_LIMIT_AUTH_LOGIN_PER_MINUTE=10
RATE_LIMIT_REGISTER_PER_HOUR=10

# Trusted proxy header. The Pi terminates the Cloudflare Tunnel locally
# via `cloudflared`, which forwards the originating client IP in
# `CF-Connecting-IP`. We trust THAT header, not `X-Forwarded-For`
# (which the tunnel egress does not authenticate end-to-end).
TRUSTED_PROXY_HEADER=CF-Connecting-IP

# Per-public-read query caps (defaults shown for documentation; uncomment
# to tighten further on a constrained Pi).
# PUBLIC_MAX_LIMIT=200
# PUBLIC_MAX_OFFSET=10000
# MAX_GEOMETRY_ATOMS_PUBLIC=500
# MAX_FULL_CALCULATIONS_PUBLIC=100
# MAX_FULL_GEOMETRIES_PUBLIC=100
# MAX_FULL_ARTIFACTS_PUBLIC=100

# OpenAPI / Swagger / ReDoc. MUST be false for public deployments.
EXPOSE_API_DOCS=false

# Legacy /api/v1/{thermo,kinetics,...} entity routes. MUST require auth
# in hosted deployments - they leak integer PKs.
LEGACY_READS_REQUIRE_AUTH=true

# Internal-ID visibility policy. MUST be false in hosted: clients use
# public refs as handles.
ALLOW_PUBLIC_INTERNAL_IDS=false

# Session cookie posture. `secure=true` because Cloudflare terminates
# TLS at the edge and the tunnel hop is TLS to `cloudflared`.
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_HTTPONLY=true

# CORS - leave empty unless a known browser-app origin needs to call
# the API. An empty list disables the CORS middleware entirely, which
# is the correct hosted default.
# CORS_ALLOW_ORIGINS=https://app.tckdb.example.org
# CORS_ALLOW_CREDENTIALS=true

# ----------------------------------------------------------------------------
# Auth / registration policy
# ----------------------------------------------------------------------------
# Closed registration. Seed accounts via scripts/bootstrap_admin.py and
# the /admin invite flow.
AUTH_ALLOW_OPEN_REGISTRATION=false

# ----------------------------------------------------------------------------
# API binding and upload worker
# ----------------------------------------------------------------------------
# Bind to localhost only - cloudflared is the only thing that talks to
# the API. There is no router port-forward.
TCKDB_API_HOST=127.0.0.1
TCKDB_API_PORT=8000

# Public base URL clients use. This is the Cloudflare-managed hostname.
TCKDB_PUBLIC_BASE_URL=https://api.tckdb.example.org/api/v1

# Inline worker is acceptable for a Pi-sized deployment. Flip to false
# and run a separate worker unit if upload volume saturates the API
# process.
TCKDB_INLINE_WORKER=true
