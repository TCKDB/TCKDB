# ============================================================================
# TCKDB - canonical Compose env template (local developer scenario)
#
# Copy to .env at the repo root:
#     cp .env.example .env
#
# Compose reads .env from the repo root automatically. This file only
# contains the variables that docker-compose.yml interpolates. Backend
# application settings (rate limits, auth policy, etc.) live separately
# in backend/.env (see backend/.env.example).
#
# For a hardened single-node server deployment, use .env.selfhosted.example
# instead and pass `--env-file .env.selfhosted` to docker compose. See
# docs/deployment/self_hosted_single_node.md.
# ============================================================================

# -- PostgreSQL (with RDKit cartridge) ---------------------------------------
# DB_USER, DB_NAME, DB_PORT have soft defaults in docker-compose.yml so a
# fresh checkout boots with `tckdb` / `tckdb_dev` on :5432. Override here
# if you collide with a host-installed Postgres.
#
# DB_PASSWORD is REQUIRED. Compose refuses to start without it.
DB_USER=tckdb
DB_PASSWORD=tckdb
DB_NAME=tckdb_dev
DB_PORT=5432

# -- MinIO / S3 artifact storage ---------------------------------------------
# S3_ACCESS_KEY has a soft default; S3_SECRET_KEY is REQUIRED.
S3_ACCESS_KEY=tckdb
S3_SECRET_KEY=tckdb_secret
